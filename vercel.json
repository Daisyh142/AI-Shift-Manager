{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["backend/**", "requirements.txt"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(auth|ai|analytics|employees|job-roles|metrics|pto|schedules|time-off|availability|coverage-requests|hours-requests|shifts|seed|docs|openapi.json|redoc)(.*)",
      "dest": "/api/index.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
